Procedure BROTRA
!---------------
!  	+----------------------------------------------------+
!  	!    Broj transakcije iz IPS001 zavisno od paketa    !
!  	+----------------------------------------------------+
!   	Table = IPS001
	if Year($DATNAL) > Year($gradat)
		$ozngod = '1'
	else
		$ozngod = '0'
	end_if

   	Read IPS001 Key = $sifra1|$sifra2|$paket|"QQ"|"QQQQ"|"QQ"|$ozngod
   	ps1_datnal = DateTime (Today,Systime)
   	if Record IPS001 not_Found
   	    ps1_sifra1 = $sifra1
   	    ps1_sifra2 = $sifra2
   	    ps1_paket  = $paket
   	    ps1_sifra4 = "QQ"
   	    ps1_sifra5 = "QQQQ"
   	    ps1_vrsnal = "QQ"
   	    ps1_ozngod = $ozngod
   	    ps1_bronal = 1
   	    Write IPS001
   	else
   	    add 1 to ps1_bronal
   	    Update IPS001
   	end_if
	$brotra = ps1_bronal
	Commit
end_Procedure

procedure progres
	select count(*) into :counter_10 from ipskom where  kom_brohod= :$Brohod \
			and 	(IPSKOM.KOM_status in \
			(:$V_STAT(1),:$V_STAT(2),:$V_STAT(3),:$V_STAT(4),:$V_STAT(5),\
			:$V_STAT(6),:$V_STAT(7),:$V_STAT(8),:$V_STAT(9),:$V_STAT(10)))
			progres.setrange(1,counter_10)
end_procedure
procedure progres1
!PAUSE $ZONREJ|'-'|$TIPHOD
	select count(*) into :counter_10 from ipskom where \
		(kom_brohod IN (Select IPSKOH.KOH_BROHOD From 			\
			IPSKOH Where IPSKOH.KOH_ZONREJ =  :$ZONREJ										\
			) OR kom_brohod IN (Select KOH_BROHOD From 								\
			IPSKOH Where IPSKOH.KOH_TIPHOD =  :$TIPHOD)) 									\
! ipskom.kom_brohod in (Select IPSKOH.KOH_BROHOD From \
!			IPSKOH Where IPSKOH.KOH_ZONREJ =  :$ZONREJ) \
			and 	(IPSKOM.KOM_status in \
			(:$V_STAT(1),:$V_STAT(2),:$V_STAT(3),:$V_STAT(4),:$V_STAT(5),\
			:$V_STAT(6),:$V_STAT(7),:$V_STAT(8),:$V_STAT(9),:$V_STAT(10)))
			progres.setrange(1,counter_10)
end_procedure

PROCEDURE DUPLI
	init $dupli
	select count(kom_brmems)into :$dupli from ipskom where KOm_sifpot= :$sifpot
END_PROCEDURE
Procedure BrisiDirektorijum
Read_External/Name: $PutSlike $putanjaf
$putanja =Alltrim($PUTANJAF)|'\Irfan\'|'*.*'
$status = FILE_IO("Delete",$putanja)

End_procedure

PROCEDURE CITCEN1
define_local $$datcen d 8
!Pause kom_sifdel
Select Max(koc_datcen) INTO :$$datcen From IPSKOC Where \
					  koc_sifra1 = :$sifra1 and koc_sifra2 = :$sifra2 and \
					  koc_sifdel = :kom_sifdel and IPSKOC.KOC_INDJOU = 'O'

!pause $$datcen

read ipskoc where IPSKOC.KOC_SIFRA1 = :$sifra1     and \
				  IPSKOC.KOC_SIFRA2 = :$sifra2     and \
				  IPSKOC.KOC_SIFDEL = :kom_sifdel  and \
				  IPSKOC.KOC_DATCEN = :$$datcen    and \
				  IPSKOC.KOC_INDJOU = 'O'

	$konto0 = ipskoc.koc_konto0
	$konkam = ipskoc.koc_konkam
	$kontuz = "BBBBB"
END_PROCEDURE

PROCEDURE CITCENA2
Define_local $$datum	d	8
Init $$datum
Init $konto0,$konkam,$kontuz,$kontak
	Select Max(koc_datcen) INTO :$$DATUM From IPSKOC Where 					\
					  koc_sifra1 = :$sifra1 and koc_sifra2 = :$sifra2 and 	\
					  koc_sifdel = :ipskom.kom_sifdel and IPSKOC.KOC_INDJOU = 'O'


read ipskoc where IPSKOC.KOC_SIFRA1 = :$sifra1     and \
				  IPSKOC.KOC_SIFRA2 = :$sifra2     and \
				  IPSKOC.KOC_SIFDEL = :ipskom.kom_sifdel   and \
				  IPSKOC.KOC_DATCEN = :$$datum      and \
				  IPSKOC.KOC_INDJOU = 'O'
If Record ipskoc Found
	$konto0 =   IPSKOC.KOC_KONTO0
	$konkam =   IPSKOC.KOC_KONKAM
	$kontuz =   IPSKOC.KOC_KONTUZ
	$kontak =   IPSKOC.KOC_KONTAK
	If	IPSKO0.KO0_KAMIND = '1'
		If $konkam = ' '
			Pause "Neuspelo preuzimanje konta kamate iz cenovnika za delatnost "|\
					ipskom.kom_sifdel|" .Potrosac sa sifrom "|ipskom.kom_sifpot
			Stop_run
		End_if
	Else
		$konkam = 'QQQQQQ'
	End_if
	If	IPSKO0.KO0_TUZIND = '1'
		If $kontuz = ' '
			Pause "Neuspelo preuzimanje konta utuženja iz cenovnika za delatnost "|\
					ipskom.kom_sifdel|" .Potrosac sa sifrom "|ipskom.kom_sifpot
			Stop_run
		End_if
		If $kontak = ' '
			Pause "Neuspelo preuzimanje konta sudskih taksi iz cenovnika za delatnost "|\
					ipskom.kom_sifdel|" .Potrosac sa sifrom "|ipskom.kom_sifpot
			Stop_run
		End_if
		!!Konto taksi i tuzbi je isti....
		If $Kontuz = $Kontak
			$kontak = 'QQQQQQ'
		End_if	
	Else
		$kontuz = 'QQQQQQ'
		$kontak = 'QQQQQQ'
	End_if	
				
Else
	Pause "Greska u citanju CENOVNIKA...za delatnost"|ipskom.kom_sifdel|" na potrosacu "|ipskom.kom_sifpot
	Stop_run
End_if
end_procedure

PROCEDURE IZDVAJANJE1
	init counter_10,COUNTER_1
	select_all * from ipskom where kom_brohod= :$Brohod 					\
			and (IPSKOM.KOM_status in 										\
			(:$V_STAT(1),:$V_STAT(2),:$V_STAT(3),:$V_STAT(4),:$V_STAT(5),  \
			:$V_STAT(6),:$V_STAT(7),:$V_STAT(8),:$V_STAT(9),:$V_STAT(10)))  \
			And (IPSKOM.KOM_PRIDUG = '1' or :IPSKO0.KO0_ABC012 <> 1)			\
		 order by kom_sifpot
		if $sifpot <> kom_sifpot
			$sifpot = kom_sifpot
			$sifvla = kom_sifpot
			perform CITCENA2
			init acc_2,acc_3,acc_4,acc_5,acc_6,acc_7,acc_8,counter_8,$STATUZ
			Select_All ak5_akonto,ak5_datnal,ak5_konto,			 							\
			    ak5_oznaka,ak5_datdok,ak5_datdpo,ak5_izndin,ak5_sifopi,ak5_vrsnal 			\
				From IPSAK5 Where                                      					 	\
				ak5_sifra1 = :$sifra1  and ak5_sifra2  = :$sifra2  and 					 	\
			    ak5_konto in (:$konto0,:$konkam,:$kontuz,:$kontak) and						\
				ak5_akonto=:$sifpot 														\
				Union  All 																	\
				Select ak2_akonto,ak2_datnal,ak2_konto,										\
					   ak2_oznaka,ak2_datdok,ak2_datdpo,ak2_izndin,ak2_sifopi,ak2_vrsnal 	\
				From IPSAK2 Where                                      						\
			    ak2_sifra1 = :$sifra1  and ak2_sifra2  = :$sifra2  and 						\
			    ak2_konto in (:$konto0,:$konkam,:$kontuz,:$kontak) and					    \
				ak2_akonto = :$sifpot														\
				Order By 1,2 desc
					If ak5_konto in ($kontuz ; $kontak)
						if ak5_oznaka = 'D'
							add  ak5_izndin to  $STATUZ	
						Else
							add -ak5_izndin to  $STATUZ
						End_if
						
					Else
						if ak5_oznaka = 'D'
							if  ak5_datnal <= $DATdug
								if ak5_konto = $konkam
									add ak5_izndin to acc_7
								end_if
								add ak5_izndin to acc_2
								if ak5_datdpo <= $datdug
									add ak5_izndin to acc_3
								end_if
							end_if
						else
						 if  ak5_datnal <= $DATpot
							if ak5_konto = $konkam
								add -ak5_izndin to acc_7
							end_if
							add ak5_izndin to acc_4
						end_if
						end_if
					
						if ak5_oznaka = 'D' & ak5_vrsnal = $vrsnalq & \
							counter_8 < $BR_RAC & ak5_izndin  > 0 & ak5_datdpo <= $datdug
							add 1 to counter_8
							add ak5_izndin to acc_8
						end_if	
					End_if		
			end_select
			
			$iznos = acc_3 - acc_4
			acc_6 = acc_2 - acc_4
	  if ($iznos => acc_8 & acc_8 => 0) or  $BR_RAC = 0
	  IF $IZNOS >= ACC_10 & $IZNOS <= ACC_11
		   INIT_RECORD IPSKOU
		    add 1 to $stavka
			select max(kou_datdok) into :$datop from ipskour where kou_sifpot=:$sifvla
			read ipskour where kou_sifpot=:$sifvla and kou_datdok=:$datop
		
		!*****************************************
			ipskou.kou_sifra1 = $sifra1 	!!  A 2
			ipskou.kou_sifra2 = $sifra2 	!!  A 2
			ipskou.kou_vrsnal = $vrsnal 	!!  A 2
			ipskou.kou_brotra = $BROTRA	!!  N 5
			ipskou.kou_godina = $GODINAB	!!  N 4
			ipskou.kou_stavka = $stavka 	!!  N 5
			ipskou.kou_brodok = IPSKOQ.KOQ_BRODOK	!!  A 9
			ipskou.kou_datdok = IPSKOQ.KOQ_DATDOK 	!!  Datetime
			ipskou.kou_sifpot = IPSKOM.KOM_SIFPOT 	!!  A 8
			ipskou.kou_brojiv = ' '	!!  A 12
			If $TUCKO = '1'
				ipskou.kou_iznos1 = $iznos + $STATUZ	!!  N 18,2
				ipskou.kou_iznos2 = acc_6	+ $STATUZ !!  N 18,2
			Else
				ipskou.kou_iznos1 = $iznos	!!  N 18,2
				ipskou.kou_iznos2 = acc_6	!!  N 18,2
			End_if
		!	ipskou.kou_iznos2 = acc_6	!!  N 18,2
			if record ipskour found
				IPSKOU.KOU_DATPRE =IPSKOUR.KOU_DATDOK
				ipskou.kou_prenal = IPSKOUR.KOU_VRSNAL	!!  A 2
				if IPSKOUR.KOU_ZALBA0='1'
					IPSKOU.KOU_ZALBA1='1'
				else
					IPSKOU.KOU_ZALBA1='0'
				end_if
			ELSE
				IPSKOU.KOU_DATPRE =ZERO_DATE
				ipskou.kou_prenal = ' '	!!  A 2
				IPSKOU.KOU_ZALBA1='0'
			END_IF

			IPSKOU.KOU_GODTU  = 0
			IPSKOU.KOU_INDPRO = '0'
			ipskou.kou_iznos3 = acc_8	!!  N 18,2
			IPSKOU.KOU_IZNKAM = acc_7
			IPSKOU.KOU_BRORAC = counter_8
			ipskou.kou_datzad = IPSKOQ.KOQ_DATZAD	!!  Datetime
			ipskou.kou_datupl = IPSKOQ.KOQ_DATUPL 	!!  Datetime
			ipskou.kou_dattuz = IPSKOQ.KOQ_DATTUZ	!!  Datetime
			ipskou.kou_statuz = ' '	!!  A 1
			ipskou.kou_oznaka = ' '	!!  A 1
			ipskou.kou_koment = ' '	!!  A 40
			IPSKOU.KOU_KONTO0 = $konto0
			IPSKOU.KOU_KONKAM = $konkam
			If kom_status in ('2')
				IPSKOU.KOU_INDSTA = '0'
				IPSKOU.KOU_INDOPO = '0'
			Else
				IPSKOU.KOU_INDSTA = '1'
				IPSKOU.KOU_INDOPO = '1'
			End_if
			IPSKOU.KOU_INDTUZ = '0'
			IPSKOU.KOU_IZNTUZ = $STATUZ
			ipskou.kou_indjou = ' '	!!  A 1	
		
			!PAUSE $IZNOS
			If $C in ('1';'2';'3';'4';'5';'9')
				IF $C='1'
					Write ipskou
					add 1 to counter_3
					$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
					poruka1.DISPLAY($text1)
				ELSE
					IF RECORD IPSKOUR FOUND
						IF $C='2'
							IF IPSKOUR.KOU_VRSNAL='OP'
							Write ipskou
							add 1 to counter_3
							$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
							poruka1.DISPLAY($text1)
							END_IF
						ELSE
							IF $C='3'
								IF IPSKOUR.KOU_VRSNAL='OT'
								Write ipskou
								add 1 to counter_3
								$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
								poruka1.DISPLAY($text1)
								END_IF
							ELSE
								IF $C='4'
									IF IPSKOUR.KOU_VRSNAL='OI'
									Write ipskou
									add 1 to counter_3
									$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
									poruka1.DISPLAY($text1)
									END_IF
								else
									IF $C='5'
										IF IPSKOUR.KOU_VRSNAL='TU'
										Write ipskou
										add 1 to counter_3
										$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
										poruka1.DISPLAY($text1)
										END_IF
									Else
										IF $C='9'
											IF IPSKOUR.KOU_VRSNAL='PT'
											Write ipskou
											add 1 to counter_3
											$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
											poruka1.DISPLAY($text1)
											END_IF
										end_if
									end_if
								END_IF
							END_IF
						END_IF
					END_IF
				END_IF
			Else
				IF $C='6'
					read ipskoug where kou_sifpot=:$sifvla and kou_vrsnal='TU'
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
				IF $C='7'
					read ipskoug where kou_sifpot=:$sifvla and kou_vrsnal = 'OP'
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno NN: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
				IF $C='8'
					read ipskoug where kou_sifpot=:$sifvla and kou_vrsnal='OT'
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
				IF $C='Q'
					read ipskoug where kou_sifpot=:$sifvla and kou_vrsnal='PT'
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
				IF $C='F'
					$DATD = SUB_YEARS ($DATNAL,1)
					Select * from ipskoug where kou_sifpot=:$sifvla and kou_vrsnal = 'OP' and \
							KOU_DATDOK > :$DATD
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
				IF $C='D'
					$DATD = SUB_YEARS ($DATNAL,1)
					Select * from ipskoug where kou_sifpot=:$sifvla and kou_vrsnal = 'OT' and \
							KOU_DATDOK > :$DATD
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
				IF $C='G'
					$DATD = SUB_YEARS ($DATNAL,1)
					Select * from ipskoug where kou_sifpot=:$sifvla and kou_vrsnal = 'PT' and \
							KOU_DATDOK > :$DATD
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
			End_if
		END_IF
!****************************************		
			
			END_IF
		end_if
		ADD  1 TO COUNTER_10
!C++ MyMsgLoop();
		pROGRES.SETPOS(COUNTER_10)
	end_select
	commit
	init acc_2,acc_3,acc_4,acc_5,acc_6,acc_7,acc_8,counter_8,$text,counter_1
END_PROCEDURE

PROCEDURE IZDVAJANJE_Uplate
	init counter_10,COUNTER_1
	select_all * from ipskom where kom_brohod= :$Brohod 	\
			and (IPSKOM.KOM_status in \
			(:$V_STAT(1),:$V_STAT(2),:$V_STAT(3),:$V_STAT(4),:$V_STAT(5),\
			:$V_STAT(6),:$V_STAT(7),:$V_STAT(8),:$V_STAT(9),:$V_STAT(10)))  	\
		 order by kom_sifpot
		if $sifpot <> kom_sifpot
			$sifpot = kom_sifpot
			$sifvla = kom_sifpot
			perform CITCENA2
			init acc_2,acc_3,acc_4,acc_5,acc_6,acc_7,acc_8,counter_8,$STATUZ
		SELECT [dbo].[func_KO_LastPayment] (:$sifpot,'',:IPSKO0.KO0_ARHBRO,:$konto0,:$konkam,'','') Into  :$dattemp
		If $dattemp < $DATdug Or $dattemp = Zero_date
!$ARHIVICA               N       1        U
!$AK2_KONTO              A       6
!$AK2_OZNAKA             A       1
!$AK2_IZNDIN             N       18,2     U
!$AK2_DATDOK             D       8
!$AK2_DATNAL             D       8
!$AK2_DATDPO             D       8
!$AK2_DUGDIN             N       18,2     U
!$AK2_POTDIN             N       18,2     U
!Select_Start  AK2_KONTO   Into :$AK2_KONTO , \
!			  AK2_DATNAL  Into :$AK2_DATNAL , \
!			  AK2_OZNAKA  Into :$AK2_OZNAKA, \
!			  AK2_IZNDIN  Into :$AK2_IZNDIN , \
!			  AK2_DATDOK  Into :$AK2_DATDOK, \
!			  AK2_DATDPO  Into :$AK2_DATDPO, \
!		      AK2_TABELA  Into :$AK2_TABELA, \
!		      AK2_DUGDIN  Into :$AK2_DUGDIN, \
!		      AK2_POTDIN  Into :$AK2_POTDIN \
!		From [dbo].[func_KO_AnalitickaKartica] ( :$sifpot ,'',:$arhivica) \
!			Where ak2_konto in (:$konto0,:$konkam,:$kontuz,:$kontak) Order by AK2_DATNAL
!End_select
			Select_All ak5_akonto,ak5_datnal,ak5_konto,			 							\
			    ak5_oznaka,ak5_datdok,ak5_datdpo,ak5_izndin,ak5_sifopi,ak5_vrsnal 			\
				From IPSAK5 Where                                      					 	\
				ak5_sifra1 = :$sifra1  and ak5_sifra2  = :$sifra2  and 					 	\
			    ak5_konto in (:$konto0,:$konkam,:$kontuz,:$kontak) and						\
				ak5_akonto=:$sifpot 														\
				Union  All 																	\
				Select ak2_akonto,ak2_datnal,ak2_konto,										\
					   ak2_oznaka,ak2_datdok,ak2_datdpo,ak2_izndin,ak2_sifopi,ak2_vrsnal 	\
				From IPSAK2 Where                                      						\
			    ak2_sifra1 = :$sifra1  and ak2_sifra2  = :$sifra2  and 						\
			    ak2_konto in (:$konto0,:$konkam,:$kontuz,:$kontak) and					    \
				ak2_akonto = :$sifpot														\
				Order By 1,2 desc
					If ak5_konto in ($kontuz ; $kontak)
						if ak5_oznaka = 'D'
							add  ak5_izndin to  $STATUZ	
						Else
							add -ak5_izndin to  $STATUZ
						End_if
						
					Else
						if ak5_oznaka = 'D'
							if  ak5_datnal <= $DATNAL
								if ak5_konto = $konkam
									add ak5_izndin to acc_7
								end_if
								add ak5_izndin to acc_2
								if ak5_datdpo <= $DATNAL
									add ak5_izndin to acc_3
								end_if
							end_if
						else
						 if  ak5_datnal <= $DATNAL
							if ak5_konto = $konkam
								add -ak5_izndin to acc_7
							end_if
							add ak5_izndin to acc_4
						end_if
						end_if
					
!						if ak5_oznaka = 'D' & ak5_vrsnal = $vrsnalq & \
!							counter_8 < $BR_RAC & ak5_izndin  > 0 & ak5_datdpo <= $datdug
!							add 1 to counter_8
!							add ak5_izndin to acc_8
!						end_if	
					End_if		
			end_select
			
			$iznos = acc_3 - acc_4
			acc_6 = acc_2 - acc_4
!	  if ($iznos => acc_8 & acc_8 => 0) or  $BR_RAC = 0
	  IF $IZNOS >= ACC_10 & $IZNOS <= ACC_11
		   INIT_RECORD IPSKOU
		    add 1 to $stavka
			select max(kou_datdok) into :$datop from ipskour where kou_sifpot=:$sifvla
			read ipskour where kou_sifpot=:$sifvla and kou_datdok=:$datop
		
		!*****************************************
			ipskou.kou_sifra1 = $sifra1 	!!  A 2
			ipskou.kou_sifra2 = $sifra2 	!!  A 2
			ipskou.kou_vrsnal = $vrsnal 	!!  A 2
			ipskou.kou_brotra = $BROTRA	!!  N 5
			ipskou.kou_godina = $GODINAB	!!  N 4
			ipskou.kou_stavka = $stavka 	!!  N 5
			ipskou.kou_brodok = IPSKOQ.KOQ_BRODOK	!!  A 9
			ipskou.kou_datdok = IPSKOQ.KOQ_DATDOK 	!!  Datetime
			ipskou.kou_sifpot = IPSKOM.KOM_SIFPOT 	!!  A 8
			ipskou.kou_brojiv = ' '	!!  A 12
			If $TUCKO = '1'
				ipskou.kou_iznos1 = $iznos + $STATUZ	!!  N 18,2
				ipskou.kou_iznos2 = acc_6	+ $STATUZ !!  N 18,2
			Else
				ipskou.kou_iznos1 = $iznos	!!  N 18,2
				ipskou.kou_iznos2 = acc_6	!!  N 18,2
			End_if
		!	ipskou.kou_iznos2 = acc_6	!!  N 18,2
			if record ipskour found
				IPSKOU.KOU_DATPRE =IPSKOUR.KOU_DATDOK
				ipskou.kou_prenal = IPSKOUR.KOU_VRSNAL	!!  A 2
				if IPSKOUR.KOU_ZALBA0='1'
					IPSKOU.KOU_ZALBA1='1'
				else
					IPSKOU.KOU_ZALBA1='0'
				end_if
			ELSE
				IPSKOU.KOU_DATPRE =ZERO_DATE
				ipskou.kou_prenal = ' '	!!  A 2
				IPSKOU.KOU_ZALBA1='0'
			END_IF

			IPSKOU.KOU_GODTU  = 0
			IPSKOU.KOU_INDPRO = '0'
			ipskou.kou_iznos3 = acc_8	!!  N 18,2
			IPSKOU.KOU_IZNKAM = acc_7
			IPSKOU.KOU_BRORAC = counter_8
			ipskou.kou_datzad = IPSKOQ.KOQ_DATZAD	!!  Datetime
			ipskou.kou_datupl = $dattemp  	!!  Datetime
			ipskou.kou_dattuz = $dattemp 	!!  Datetime
			ipskou.kou_statuz = ' '	!!  A 1
			ipskou.kou_oznaka = ' '	!!  A 1
			ipskou.kou_koment = ' '	!!  A 40
			IPSKOU.KOU_KONTO0 = $konto0
			IPSKOU.KOU_KONKAM = $konkam
			If kom_status in ('2')
				IPSKOU.KOU_INDSTA = '0'
				IPSKOU.KOU_INDOPO = '0'
			Else
				IPSKOU.KOU_INDSTA = '1'
				IPSKOU.KOU_INDOPO = '1'
			End_if
			IPSKOU.KOU_INDTUZ = '0'
			IPSKOU.KOU_IZNTUZ = $STATUZ
			ipskou.kou_indjou = ' '	!!  A 1	
!			IPSKOU.KOU_INDIK0
!			IPSKOU.KOU_INDIK1
!			IPSKOU.KOU_INDIK2

			If $dattemp = Zero_date
				IPSKOU.KOU_INDIK3 = 99999
			Else
				IPSKOU.KOU_INDIK3 = DIFF_DAYS($dattemp,today)
			End_IF
		
			!PAUSE $IZNOS
			If $C in ('1';'2';'3';'4';'5';'9')
				IF $C='1'
					Write ipskou
					add 1 to counter_3
					$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
					poruka1.DISPLAY($text1)
				ELSE
					IF RECORD IPSKOUR FOUND
						IF $C='2'
							IF IPSKOUR.KOU_VRSNAL='OP'
							Write ipskou
							add 1 to counter_3
							$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
							poruka1.DISPLAY($text1)
							END_IF
						ELSE
							IF $C='3'
								IF IPSKOUR.KOU_VRSNAL='OT'
								Write ipskou
								add 1 to counter_3
								$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
								poruka1.DISPLAY($text1)
								END_IF
							ELSE
								IF $C='4'
									IF IPSKOUR.KOU_VRSNAL='OI'
									Write ipskou
									add 1 to counter_3
									$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
									poruka1.DISPLAY($text1)
									END_IF
								else
									IF $C='5'
										IF IPSKOUR.KOU_VRSNAL='TU'
										Write ipskou
										add 1 to counter_3
										$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
										poruka1.DISPLAY($text1)
										END_IF
									Else
										IF $C='9'
											IF IPSKOUR.KOU_VRSNAL='PT'
											Write ipskou
											add 1 to counter_3
											$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
											poruka1.DISPLAY($text1)
											END_IF
										end_if
									end_if
								END_IF
							END_IF
						END_IF
					END_IF
				END_IF
			Else
				IF $C='6'
					read ipskoug where kou_sifpot=:$sifvla and kou_vrsnal='TU'
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
				IF $C='7'
					read ipskoug where kou_sifpot=:$sifvla and kou_vrsnal = 'OP'
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno NN: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
				IF $C='8'
					read ipskoug where kou_sifpot=:$sifvla and kou_vrsnal='OT'
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
				IF $C='Q'
					read ipskoug where kou_sifpot=:$sifvla and kou_vrsnal='PT'
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
				IF $C='F'
					$DATD = SUB_YEARS ($DATNAL,1)
					Select * from ipskoug where kou_sifpot=:$sifvla and kou_vrsnal = 'OP' and \
							KOU_DATDOK > :$DATD
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
				IF $C='D'
					$DATD = SUB_YEARS ($DATNAL,1)
					Select * from ipskoug where kou_sifpot=:$sifvla and kou_vrsnal = 'OT' and \
							KOU_DATDOK > :$DATD
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
				IF $C='G'
					$DATD = SUB_YEARS ($DATNAL,1)
					Select * from ipskoug where kou_sifpot=:$sifvla and kou_vrsnal = 'PT' and \
							KOU_DATDOK > :$DATD
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
			End_if
		END_IF
!****************************************		
			
!		END_IF
		end_if
		End_IF
		ADD  1 TO COUNTER_10
!C++ MyMsgLoop();
		pROGRES.SETPOS(COUNTER_10)
	end_select
	commit
	init acc_2,acc_3,acc_4,acc_5,acc_6,acc_7,acc_8,counter_8,$text,counter_1
END_PROCEDURE


PROCEDURE IZDVAJANJE_ZON
	init counter_10,COUNTER_1
	select_all * from ipskom where kom_brohod IN (Select IPSKOH.KOH_BROHOD From 			\
			IPSKOH Where IPSKOH.KOH_ZONREJ =  :$ZONREJ) 									\
			and (IPSKOM.KOM_status in 														\
			(:$V_STAT(1),:$V_STAT(2),:$V_STAT(3),:$V_STAT(4),:$V_STAT(5),					\
			:$V_STAT(6),:$V_STAT(7),:$V_STAT(8),:$V_STAT(9),:$V_STAT(10)))  				\
			And (IPSKOM.KOM_PRIDUG = '1' or :IPSKO0.KO0_ABC012 <> 1)						\
		 order by kom_sifpot
		if $sifpot <> kom_sifpot
			$sifpot = kom_sifpot
			$sifvla = kom_sifpot
			perform CITCENA2
			init acc_2,acc_3,acc_4,acc_5,acc_6,acc_7,acc_8,counter_8,$STATUZ
			Select_All ak5_akonto,ak5_datnal,ak5_konto,			 							\
			    ak5_oznaka,ak5_datdok,ak5_datdpo,ak5_izndin,ak5_sifopi,ak5_vrsnal 			\
				From IPSAK5 Where                                      					 	\
				ak5_sifra1 = :$sifra1  and ak5_sifra2  = :$sifra2  and 					 	\
			    ak5_konto in (:$konto0,:$konkam,:$kontuz,:$kontak) and						\
				ak5_akonto=:$sifpot 														\
				Union  All 																	\
				Select ak2_akonto,ak2_datnal,ak2_konto,										\
					   ak2_oznaka,ak2_datdok,ak2_datdpo,ak2_izndin,ak2_sifopi,ak2_vrsnal 	\
				From IPSAK2 Where                                      						\
			    ak2_sifra1 = :$sifra1  and ak2_sifra2  = :$sifra2  and 						\
			    ak2_konto in (:$konto0,:$konkam,:$kontuz,:$kontak) and					    \
				ak2_akonto = :$sifpot														\
				Order By 1,2 desc
					If ak5_konto in ($kontuz ; $kontak)
						if ak5_oznaka = 'D'
							add  ak5_izndin to $STATUZ	
						Else
							add -ak5_izndin to  $STATUZ
						End_if
						
					Else
						if ak5_oznaka = 'D'
							if  ak5_datnal <= $DATdug
								if ak5_konto = $konkam
									add ak5_izndin to acc_7
								end_if
								add ak5_izndin to acc_2
								if ak5_datdpo <= $datdug
									add ak5_izndin to acc_3
								end_if
							end_if
						else
						 if  ak5_datnal <= $DATpot
							if ak5_konto = $konkam
								add -ak5_izndin to acc_7
							end_if
							add ak5_izndin to acc_4
						end_if
						end_if
					
						if ak5_oznaka = 'D' & ak5_vrsnal = $vrsnalq & \
							counter_8 < $BR_RAC & ak5_izndin  > 0 & ak5_datdpo <= $datdug
							add 1 to counter_8
							add ak5_izndin to acc_8
						end_if	
					End_if		
			end_select
			
			$iznos = acc_3 - acc_4
			acc_6 = acc_2 - acc_4
	  if ($iznos => acc_8 & acc_8 => 0) or  $BR_RAC = 0
	  IF $IZNOS >= ACC_10 & $IZNOS <= ACC_11
		   INIT_RECORD IPSKOU
		    add 1 to $stavka
			select max(kou_datdok) into :$datop from ipskour where kou_sifpot=:$sifvla
			read ipskour where kou_sifpot=:$sifvla and kou_datdok=:$datop
		
		!*****************************************
			ipskou.kou_sifra1 = $sifra1 	!!  A 2
			ipskou.kou_sifra2 = $sifra2 	!!  A 2
			ipskou.kou_vrsnal = $vrsnal 	!!  A 2
			ipskou.kou_brotra = $BROTRA	!!  N 5
			ipskou.kou_godina = $GODINAB	!!  N 4
			ipskou.kou_stavka = $stavka 	!!  N 5
			ipskou.kou_brodok = IPSKOQ.KOQ_BRODOK	!!  A 9
			ipskou.kou_datdok = IPSKOQ.KOQ_DATDOK 	!!  Datetime
			ipskou.kou_sifpot = IPSKOM.KOM_SIFPOT 	!!  A 8
			ipskou.kou_brojiv = ' '	!!  A 12
			If $TUCKO = '1'
				ipskou.kou_iznos1 = $iznos + $STATUZ	!!  N 18,2
				ipskou.kou_iznos2 = acc_6+ $STATUZ	!!  N 18,2
			Else
				ipskou.kou_iznos1 = $iznos	!!  N 18,2
				ipskou.kou_iznos2 = acc_6	!!  N 18,2
			End_if
		!	ipskou.kou_iznos2 = acc_6	!!  N 18,2
			if record ipskour found
				IPSKOU.KOU_DATPRE =IPSKOUR.KOU_DATDOK
				ipskou.kou_prenal = IPSKOUR.KOU_VRSNAL	!!  A 2
				if IPSKOUR.KOU_ZALBA0='1'
					IPSKOU.KOU_ZALBA1='1'
				else
					IPSKOU.KOU_ZALBA1='0'
				end_if
			ELSE
				IPSKOU.KOU_DATPRE =ZERO_DATE
				ipskou.kou_prenal = ' '	!!  A 2
				IPSKOU.KOU_ZALBA1='0'
			END_IF

			IPSKOU.KOU_GODTU  = 0
			IPSKOU.KOU_INDPRO = '0'
			ipskou.kou_iznos3 = acc_8	!!  N 18,2
			IPSKOU.KOU_IZNKAM = acc_7
			IPSKOU.KOU_BRORAC = counter_8
			ipskou.kou_datzad = IPSKOQ.KOQ_DATZAD	!!  Datetime
			ipskou.kou_datupl = IPSKOQ.KOQ_DATUPL 	!!  Datetime
			ipskou.kou_dattuz = IPSKOQ.KOQ_DATTUZ	!!  Datetime
			ipskou.kou_statuz = ' '	!!  A 1
			ipskou.kou_oznaka = ' '	!!  A 1
			ipskou.kou_koment = ' '	!!  A 40
			IPSKOU.KOU_KONTO0 = $konto0
			IPSKOU.KOU_KONKAM = $konkam
			If kom_status in ('2')
				IPSKOU.KOU_INDSTA = '0'
				IPSKOU.KOU_INDOPO = '0'
			Else
				IPSKOU.KOU_INDSTA = '1'
				IPSKOU.KOU_INDOPO = '1'
			End_if
			IPSKOU.KOU_INDTUZ = '0'
			IPSKOU.KOU_IZNTUZ = $STATUZ
			ipskou.kou_indjou = ' '	!!  A 1	
		
			!PAUSE $IZNOS
			
			If $C in ('1';'2';'3';'4';'5';'9')
				IF $C='1'
					Write ipskou
					add 1 to counter_3
					$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
					poruka1.DISPLAY($text1)
				ELSE
					IF RECORD IPSKOUR FOUND
						IF $C='2'
							IF IPSKOUR.KOU_VRSNAL='OP'
							Write ipskou
							add 1 to counter_3
							$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
							poruka1.DISPLAY($text1)
							END_IF
						ELSE
							IF $C='3'
								IF IPSKOUR.KOU_VRSNAL='OT'
								Write ipskou
								add 1 to counter_3
								$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
								poruka1.DISPLAY($text1)
								END_IF
							ELSE
								IF $C='4'
									IF IPSKOUR.KOU_VRSNAL='OI'
									Write ipskou
									add 1 to counter_3
									$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
									poruka1.DISPLAY($text1)
									END_IF
								else
									IF $C='5'
										IF IPSKOUR.KOU_VRSNAL='TU'
										Write ipskou
										add 1 to counter_3
										$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
										poruka1.DISPLAY($text1)
										END_IF
									Else
										IF $C='9'
											IF IPSKOUR.KOU_VRSNAL='PT'
											Write ipskou
											add 1 to counter_3
											$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
											poruka1.DISPLAY($text1)
											END_IF
										end_if
									end_if
								END_IF
							END_IF
						END_IF
					END_IF
				END_IF
			Else
				IF $C='6'
					read ipskoug where kou_sifpot=:$sifvla and kou_vrsnal='TU'
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
				IF $C='7'
					read ipskoug where kou_sifpot=:$sifvla and kou_vrsnal = 'OP'
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno NN: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
				IF $C='8'
					read ipskoug where kou_sifpot=:$sifvla and kou_vrsnal='OT'
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
				IF $C='Q'
					read ipskoug where kou_sifpot=:$sifvla and kou_vrsnal='PT'
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
				IF $C='F'
					$DATD = SUB_YEARS ($DATNAL,1)
					Select * from ipskoug where kou_sifpot=:$sifvla and kou_vrsnal = 'OP' and \
							KOU_DATDOK > :$DATD
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
				IF $C='D'
					$DATD = SUB_YEARS ($DATNAL,1)
					Select * from ipskoug where kou_sifpot=:$sifvla and kou_vrsnal = 'OT' and \
							KOU_DATDOK > :$DATD
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
				IF $C='G'
					$DATD = SUB_YEARS ($DATNAL,1)
					Select * from ipskoug where kou_sifpot=:$sifvla and kou_vrsnal = 'PT' and \
							KOU_DATDOK > :$DATD
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
			End_if
		END_IF
!****************************************		
			
		END_IF
		end_if
		ADD  1 TO COUNTER_10
!C++ MyMsgLoop();
		pROGRES.SETPOS(COUNTER_10)
	end_select
	commit
	init acc_2,acc_3,acc_4,acc_5,acc_6,acc_7,acc_8,counter_8,$text,counter_1
END_PROCEDURE


PROCEDURE IZDVAJANJE8
	init counter_10,COUNTER_1
	select_all * from ipskom where kom_brohod= :$Brohod 	\
			and (IPSKOM.KOM_status in \
			(:$V_STAT(1),:$V_STAT(2),:$V_STAT(3),:$V_STAT(4),:$V_STAT(5),\
			:$V_STAT(6),:$V_STAT(7),:$V_STAT(8),:$V_STAT(9),:$V_STAT(10)))  	\
			And (IPSKOM.KOM_PRIDUG = '1' or :IPSKO0.KO0_ABC012 <> 1)			\
		 order by kom_sifpot
		if $sifpot <> kom_sifpot
			$sifpot = kom_sifpot
			$sifvla = kom_sifpot
			perform CITCENA2
			init acc_2,acc_3,acc_4,acc_5,acc_6,acc_7,acc_8,counter_8,$STATUZ
			Select_All ak5_akonto,ak5_datnal,ak5_konto,			 							\
			    ak5_oznaka,ak5_datdok,ak5_datdpo,ak5_izndin,ak5_sifopi,ak5_vrsnal 			\
				From IPSAK5 Where                                      					 	\
				ak5_sifra1 = :$sifra1  and ak5_sifra2  = :$sifra2  and 					 	\
			    ak5_konto in (:$konto0,:$konkam,:$kontuz,:$kontak) and						\
				ak5_akonto=:$sifpot 														\
				Union  All 																	\
				Select ak2_akonto,ak2_datnal,ak2_konto,										\
					   ak2_oznaka,ak2_datdok,ak2_datdpo,ak2_izndin,ak2_sifopi,ak2_vrsnal 	\
				From IPSAK2 Where                                      						\
			    ak2_sifra1 = :$sifra1  and ak2_sifra2  = :$sifra2  and 						\
			    ak2_konto in (:$konto0,:$konkam,:$kontuz,:$kontak) and					    \
				ak2_akonto = :$sifpot														\
				Order By 1,2 desc
					If ak5_konto in ($kontuz ; $kontak)
						if ak5_oznaka = 'D'
							add  ak5_izndin to $STATUZ	
						Else
							add -ak5_izndin to  $STATUZ
						End_if
						
					Else
						if ak5_oznaka = 'D'
							if  ak5_datnal <= $DATdug
								if ak5_konto = $konkam
									add ak5_izndin to acc_7
								end_if
								add ak5_izndin to acc_2
								if ak5_datdpo <= $datdug
									add ak5_izndin to acc_3
								end_if
							end_if
						else
						 if  ak5_datnal <= $DATpot
							if ak5_konto = $konkam
								add -ak5_izndin to acc_7
							end_if
							add ak5_izndin to acc_4
						end_if
						end_if
					End_if		
			end_select
			
			$iznos = acc_3 - acc_4
			acc_6 = acc_2 - acc_4
	  IF $statuz >= ACC_10 & $statuz <= ACC_11
		   INIT_RECORD IPSKOU
		    add 1 to $stavka
			select max(kou_datdok) into :$datop from ipskour where kou_sifpot=:$sifvla
			read ipskour where kou_sifpot=:$sifvla and kou_datdok=:$datop
		
		!*****************************************
			ipskou.kou_sifra1 = $sifra1 	!!  A 2
			ipskou.kou_sifra2 = $sifra2 	!!  A 2
			ipskou.kou_vrsnal = $vrsnal 	!!  A 2
			ipskou.kou_brotra = $BROTRA	!!  N 5
			ipskou.kou_godina = $GODINAB	!!  N 4
			ipskou.kou_stavka = $stavka 	!!  N 5
			ipskou.kou_brodok = IPSKOQ.KOQ_BRODOK	!!  A 9
			ipskou.kou_datdok = IPSKOQ.KOQ_DATDOK 	!!  Datetime
			ipskou.kou_sifpot = IPSKOM.KOM_SIFPOT 	!!  A 8
			ipskou.kou_brojiv = ' '	!!  A 12
			If $TUCKO = '1'
				ipskou.kou_iznos1 = $iznos + $STATUZ	!!  N 18,2
				ipskou.kou_iznos2 = acc_6	+ $STATUZ	!!  N 18,2
			Else
				ipskou.kou_iznos1 = $iznos	!!  N 18,2
				ipskou.kou_iznos2 = acc_6	!!  N 18,2
			End_if
		!	ipskou.kou_iznos2 = acc_6	!!  N 18,2
			if record ipskour found
				IPSKOU.KOU_DATPRE =IPSKOUR.KOU_DATDOK
				ipskou.kou_prenal = IPSKOUR.KOU_VRSNAL	!!  A 2
				if IPSKOUR.KOU_ZALBA0='1'
					IPSKOU.KOU_ZALBA1='1'
				else
					IPSKOU.KOU_ZALBA1='0'
				end_if
			ELSE
				IPSKOU.KOU_DATPRE =ZERO_DATE
				ipskou.kou_prenal = ' '	!!  A 2
				IPSKOU.KOU_ZALBA1='0'
			END_IF

			IPSKOU.KOU_GODTU  = 0
			IPSKOU.KOU_INDPRO = '0'
			ipskou.kou_iznos3 =  $iznos	!!  N 18,2
			IPSKOU.KOU_IZNKAM = acc_7
			IPSKOU.KOU_BRORAC = counter_8
			ipskou.kou_datzad = IPSKOQ.KOQ_DATZAD	!!  Datetime
			ipskou.kou_datupl = IPSKOQ.KOQ_DATUPL 	!!  Datetime
			ipskou.kou_dattuz = IPSKOQ.KOQ_DATTUZ	!!  Datetime
			ipskou.kou_statuz = ' '	!!  A 1
			ipskou.kou_oznaka = ' '	!!  A 1
			ipskou.kou_koment = ' '	!!  A 40
			IPSKOU.KOU_KONTO0 = $konto0
			IPSKOU.KOU_KONKAM = $konkam
			If kom_status in ('2')
				IPSKOU.KOU_INDSTA = '0'
				IPSKOU.KOU_INDOPO = '0'
			Else
				IPSKOU.KOU_INDSTA = '1'
				IPSKOU.KOU_INDOPO = '1'
			End_if
			IPSKOU.KOU_INDTUZ = '0'
			IPSKOU.KOU_IZNTUZ = $STATUZ
			ipskou.kou_indjou = ' '	!!  A 1	
		
			!PAUSE $IZNOS
			If $C in ('1';'2';'3';'4';'5';'9')
				IF $C='1'
					Write ipskou
					add 1 to counter_3
					$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
					poruka1.DISPLAY($text1)
				ELSE
					IF RECORD IPSKOUR FOUND
						IF $C='2'
							IF IPSKOUR.KOU_VRSNAL='OP'
							Write ipskou
							add 1 to counter_3
							$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
							poruka1.DISPLAY($text1)
							END_IF
						ELSE
							IF $C='3'
								IF IPSKOUR.KOU_VRSNAL='OT'
								Write ipskou
								add 1 to counter_3
								$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
								poruka1.DISPLAY($text1)
								END_IF
							ELSE
								IF $C='4'
									IF IPSKOUR.KOU_VRSNAL='OI'
									Write ipskou
									add 1 to counter_3
									$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
									poruka1.DISPLAY($text1)
									END_IF
								else
									IF $C='5'
										IF IPSKOUR.KOU_VRSNAL='TU'
										Write ipskou
										add 1 to counter_3
										$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
										poruka1.DISPLAY($text1)
										END_IF
									Else
										IF $C='9'
											IF IPSKOUR.KOU_VRSNAL='PT'
											Write ipskou
											add 1 to counter_3
											$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
											poruka1.DISPLAY($text1)
											END_IF
										end_if
									end_if
								END_IF
							END_IF
						END_IF
					END_IF
				END_IF
			Else
				IF $C='6'
					read ipskoug where kou_sifpot=:$sifvla and kou_vrsnal='TU'
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
				IF $C='7'
					read ipskoug where kou_sifpot=:$sifvla and kou_vrsnal = 'OP'
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno NN: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
				IF $C='8'
					read ipskoug where kou_sifpot=:$sifvla and kou_vrsnal='OT'
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
				IF $C='Q'
					read ipskoug where kou_sifpot=:$sifvla and kou_vrsnal='PT'
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
				IF $C='F'
					$DATD = SUB_YEARS ($DATNAL,1)
					Select * from ipskoug where kou_sifpot=:$sifvla and kou_vrsnal = 'OP' and \
							KOU_DATDOK > :$DATD
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
				IF $C='D'
					$DATD = SUB_YEARS ($DATNAL,1)
					Select * from ipskoug where kou_sifpot=:$sifvla and kou_vrsnal = 'OT' and \
							KOU_DATDOK > :$DATD
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if
				IF $C='G'
					$DATD = SUB_YEARS ($DATNAL,1)
					Select * from ipskoug where kou_sifpot=:$sifvla and kou_vrsnal = 'PT' and \
							KOU_DATDOK > :$DATD
						if record ipskoug not_found
						Write ipskou
						add 1 to counter_3
						$text1=compress("Izvojeno: ",edit(counter_3,"zzzzz9"),"...")
						poruka1.DISPLAY($text1)
					end_if
				end_if

		!	End_if
		END_IF
!****************************************		
			
			END_IF
		end_if
		ADD  1 TO COUNTER_10
!C++ MyMsgLoop();
		pROGRES.SETPOS(COUNTER_10)
	end_select
	commit
	init acc_2,acc_3,acc_4,acc_5,acc_6,acc_7,acc_8,counter_8,$text,counter_1
END_PROCEDURE


PROCEDURE BRISANJE
	ExecSQL delete ipskoq                                                   \
			Where IPSKOq.KOq_SIFRA1=:$sifra1 and IPSKOq.KOq_SIFRA2=:$sifra2 \
			and IPSKOq.KOq_VRSNAL=:$vrsnal and IPSKOq.KOq_BROTRA=:$brotra   \
			and IPSKOq.KOq_GODINA=:$godinab

	ExecSQL delete ipskou                                                   \
			Where IPSKOU.KOU_SIFRA1=:$sifra1 and IPSKOU.KOU_SIFRA2=:$sifra2 \
			and IPSKOU.KOU_VRSNAL=:$vrsnal and IPSKOU.KOU_BROTRA=:$brotra\
			and IPSKOU.KOU_GODINA=:$godinab
		if $isRep = 1
		ExecSQL delete ipskon                                                   \
			Where IPSKOn.KOn_SIFRA1=:$sifra1 and IPSKOn.KOn_SIFRA2=:$sifra2 \
			and IPSKOn.KOn_VRSNAL=:$vrsnal and IPSKOn.KOn_BROTRA=:$brotra\
			and IPSKOn.KOn_GODINA=:$godinab
		End_IF
	commit


	
END_PROCEDURE

PROCEDURE IZLAZ
	Define_local $$Sifrej a 4
	Define_local $$Sifprj a 2
	Define_local $$Brmems n 5
	
	ExecSQL delete ipskou                                                   \
			Where IPSKOU.KOU_SIFRA1=:$sifra1 and IPSKOU.KOU_SIFRA2=:$sifra2 \
			and IPSKOU.KOU_VRSNAL=:$vrsnal and IPSKOU.KOU_BROTRA=:$brotra   \
			and IPSKOU.KOU_GODINA=:$godinab and IPSKOU.KOU_INDOPO='0'
	COMMIT
	ExecSQL update ipskoq set IPSKOQ.KOQ_OVERA='O' FROM IPSKOQ              \
			Where  IPSKOq.KOq_SIFRA1=:$sifra1 and IPSKOq.KOq_SIFRA2=:$sifra2 \
			       and IPSKOq.KOq_VRSNAL=:$vrsnal and IPSKOq.KOq_BROTRA=:$brotra   \
			       and IPSKOq.KOq_GODINA=:$godinab
	COMMIT
	If  IPSKO0.KO0_ETAZNI >  0 and IPSKO0.KO0_INTX01 = 1
		Select_all IPSKOU.KOU_SIFPOT from ipskou 									\
			Where IPSKOU.KOU_SIFRA1=:$sifra1 and IPSKOU.KOU_SIFRA2=:$sifra2 		\
				  and IPSKOU.KOU_VRSNAL=:$vrsnal and IPSKOU.KOU_BROTRA=:$brotra   	\
				  and IPSKOU.KOU_GODINA=:$godinab

			Select  IPSKOM.KOM_SIFREJ into :$$Sifrej,	\
					IPSKOM.KOM_SIFPRJ into :$$Sifprj, 	\
					IPSKOM.KOM_BRMEMS into :$$Brmems  	\
					From Ipskom where IPSKOM.KOM_SIFPOT = :IPSKOU.KOU_SIFPOT

					Read ipskok Key = $$Sifrej|$$Sifprj|$$Brmems
					If Record Ipskok Found
						IPSKOK.KOK_ETAZNI = IPSKOK.KOK_ETAZNI + 1
						Update IPSKOK/Cond:IPSKOK.KOK_ETAZNI <= 9
					End_if
		End_select
		Commit
	End_if
		if $isRep = 1
			ExecSQL  Delete IPSKON \
			FROM            dbo.IPSKON INNER JOIN \
                         dbo.IPSKOU ON dbo.IPSKON.KON_SIFRA1 = dbo.IPSKOU.KOU_SIFRA1 AND \
						 dbo.IPSKON.KON_SIFRA2 = dbo.IPSKOU.KOU_SIFRA2 AND \
						 dbo.IPSKON.KON_VRSNAL = dbo.IPSKOU.KOU_VRSNAL AND  \
                         dbo.IPSKON.KON_GODINA = dbo.IPSKOU.KOU_GODINA AND \
						 dbo.IPSKON.KON_BROTRA = dbo.IPSKOU.KOU_BROTRA AND \
						 dbo.IPSKON.KON_STAVKA = dbo.IPSKOU.KOU_STAVKA \
						Where IPSKOU.KOU_SIFRA1=:$sifra1 and IPSKOU.KOU_SIFRA2=:$sifra2 \
						and IPSKOU.KOU_VRSNAL=:$vrsnal and IPSKOU.KOU_BROTRA=:$brotra   \
						and IPSKOU.KOU_GODINA=:$godinab and IPSKOU.KOU_INDOPO='0'
				commit
		End_IF
	
END_PROCEDURE

PROCEDURE MESEC
	$text1  = 'Januar' /cond:koq_mesec = 1
	$text1  = 'Februar' /cond:koq_mesec = 2
	$text1  = 'Mart' /cond:koq_mesec = 3
	$text1  = 'April' /cond:koq_mesec = 4
	$text1  = 'Maj' /cond:koq_mesec = 5
	$text1  = 'Jun' /cond:koq_mesec = 6
	$text1  = 'Jul' /cond:koq_mesec = 7
	$text1  = 'August' /cond:koq_mesec = 8
	$text1  = 'Septembar' /cond:koq_mesec = 9
	$text1  = 'Oktobar' /cond:koq_mesec = 10
	$text1  = 'Novembar' /cond:koq_mesec = 11
	$text1  = 'Decembar' /cond:koq_mesec = 12
	mesec.display($text1)

END_PROCEDURE

PROCEDURE IZDVAJANJE2
init acc_2,acc_5,$STATUZ
$sifpot = IPSKOU.KOU_SIFPOT
!pause $konto0
Select_All ak5_akonto,ak5_datnal,ak5_konto,			 										\
			    ak5_oznaka,ak5_datdok,ak5_datdpo,ak5_izndin,ak5_sifopi,ak5_vrsnal 			\
				From IPSAK5 Where                                      					 	\
				ak5_sifra1 = :$sifra1  and ak5_sifra2  = :$sifra2  and 					 	\
			    ak5_konto in (:$konto0,:$konkam) and						\
				ak5_akonto=:$sifpot 														\
				Union  All 																	\
				Select ak2_akonto,ak2_datnal,ak2_konto,										\
					   ak2_oznaka,ak2_datdok,ak2_datdpo,ak2_izndin,ak2_sifopi,ak2_vrsnal 	\
				From IPSAK2 Where                                      						\
			    ak2_sifra1 = :$sifra1  and ak2_sifra2  = :$sifra2  and 						\
			    ak2_konto in (:$konto0,:$konkam) and						\
				ak2_akonto = :$sifpot														\
				Order By 1,2 desc
					If ak5_konto in ($kontuz ; $kontak)
						if ak5_oznaka = 'D'
							add  ak5_izndin to $STATUZ	
						Else
							add -ak5_izndin to  $STATUZ
						End_if
						
					Else
						if ak5_oznaka = 'D'
							if ak5_datdpo <= $datupl
								add ak5_izndin to acc_2
							end_if
						else
							add -ak5_izndin to acc_2
							if AK5_DATNAL <= $datupl &  \
							 	AK5_DATNAL >= KOQ_DATDOK
								add ak5_izndin to acc_5	
							end_if
						end_if
					End_if
end_select
END_PROCEDURE

PROCEDURE EXCEL1
	init $estat
$estat = excel.Open() !!create new, empty document
if $estat <> 0
Pause "Excel error: " | $estat
else
init counter_1
add 1 to counter_1
$estat = excel.Setcell(counter_1,1,"Vrsta naloga")
$estat = excel.Setcell(counter_1,2,"Broj opomene")
$estat = excel.Setcell(counter_1,3,"Datum")
$estat = excel.Setcell(counter_1,4,"Šifra naloga")
$estat = excel.Setcell(counter_1,5,"HODOGRAM")
$estat = excel.Setcell(counter_1,6,"Mesec")
$estat = excel.Setcell(counter_1,7,"Broj izdvojenih opomena")
$estat = excel.Setcell(counter_1,8,"Dug OPOMENE")
$estat = excel.Setcell(counter_1,9,"Uplata")
$estat = excel.Setcell(counter_1,10,"Trenutno stanje")
$estat = excel.Setcell(counter_1,11,"Procenat naplate")
read_all EXCIPSKOq
add 1 to counter_1
	$estat = excel.Setcell(counter_1,1,LIST("OPOMENE",EXCIPSKOQ.KOQ_VRSNAL, 25 ))
	$estat = excel.Setcell(counter_1,2,EXCIPSKOQ.KOQ_brotra)
	$estat = excel.Setcell(counter_1,3,EXCIPSKOQ.KOQ_DATDOK)
	$estat = excel.Setcell(counter_1,4,EXCIPSKOQ.KOQ_brodok)
	$estat = excel.Setcell(counter_1,5,EXCIPSKOQ.KOQ_BROHOD)
	perform mesec
	$estat = excel.Setcell(counter_1,6,initcap($text1))
	$estat = excel.Setcell(counter_1,7,edit(EXCIPSKOQ.KOQ_IZNOS6,"zzzzzz9"))
	$estat = excel.Setcell(counter_1,8,EXCIPSKOQ.KOQ_IZNOS1)
	$estat = excel.Setcell(counter_1,9,EXCIPSKOQ.KOQ_IZNOS4)
	$estat = excel.Setcell(counter_1,10,EXCIPSKOQ.KOQ_IZNOS5)
	$estat = excel.Setcell(counter_1,11,EXCIPSKOQ.KOQ_PROCEN)
end_read
$putanja = alltrim($putanja)|"\OPOMENE_zb.xls"
$estat = excel.Run("save_exit", $putanja)
end_if

END_PROCEDURE

