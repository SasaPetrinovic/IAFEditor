	$estat = excel.Setcell(counter_1,6,EXCIPSKOU.KOU_IZNKAM)
	$estat = excel.Setcell(counter_1,7,EXCIPSKOU.KOU_IZNOS4)
	$estat = excel.Setcell(counter_1,8,EXCIPSKOU.KOU_IZNOS5)
	$estat = excel.Setcell(counter_1,9,EXCIPSKOU.KOU_IZNOS6)
