{
  "IF block": {
    "prefix": "if",
    "body": [
      "IF ${1:condition}",
      "    ${0}",
      "END_IF"
    ],
    "description": "IAF IF / END_IF block"
  },
  "IF ELSE block": {
    "prefix": "ife",
    "body": [
      "IF ${1:condition}",
      "    ${2}",
      "ELSE",
      "    ${0}",
      "END_IF"
    ],
    "description": "IAF IF / ELSE / END_IF block"
  },
  "DO WHILE block": {
    "prefix": "dow",
    "body": [
      "DO_WHILE ${1:condition}",
      "    ${0}",
      "END_DO"
    ],
    "description": "IAF DO_WHILE / END_DO block"
  },
  "SELECT ALL block": {
    "prefix": "selectall",
    "body": [
      "SELECT_ALL ${1:table}",
      "    ${0}",
      "END_SELECT"
    ],
    "description": "IAF SELECT_ALL / END_SELECT block"
  },
  "EXECSQL update": {
    "prefix": "execsqlupdate",
    "body": [
      "EXECSQL update ${1:table} set ${2:field} = ${3:value} where ${4:condition}"
    ],
    "description": "IAF EXECSQL update statement"
  },
  "Procedure": {
    "prefix": "procedure",
    "body": [
      "PROCEDURE ${1:name}",
      "    ${0}",
      "END_PROCEDURE"
    ],
    "description": "IAF PROCEDURE / END_PROCEDURE block"
  },
  "Read all block": {
    "prefix": "readall",
    "body": [
      "READ_ALL ${1:source}",
      "    ${0}",
      "END_READ"
    ],
    "description": "IAF READ_ALL / END_READ block"
  }
}
